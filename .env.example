# ------------------------------------------------------------------
# Life Wishlist — Environment Variables
# Copy this file to `.env` and fill in the values.
# ------------------------------------------------------------------

# PostgreSQL connection string (Supabase → Project Settings → Database).
# Use the "Connection Pooling" (pgBouncer, port 6543) URL for the app at runtime.
DATABASE_URL="postgresql://postgres:password@localhost:5432/wishlist?schema=public"

# Direct (non-pooled) connection — used by Prisma Migrate / db push.
# On Supabase this is the port 5432 URL. Locally it can equal DATABASE_URL.
DIRECT_URL="postgresql://postgres:password@localhost:5432/wishlist?schema=public"

# Secret used to sign admin session JWTs. Generate a strong one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL of the deployment (used for share links / QR codes).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: seed the first admin password non-interactively (used by `npm run db:seed`).
# If omitted, the app shows a first-run /setup screen to create the admin password.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD=""
